@using CAT.AID.Models
@using CAT.AID.Models.DTO
@model Assessment

@{
var sections = ViewBag.Sections as List<AssessmentSection> ?? new();

```
var saved = string.IsNullOrWhiteSpace(Model.AssessmentResultJson)
    ? new Dictionary<string, string>()
    : System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(Model.AssessmentResultJson)!;

bool editable = Model.IsEditableByAssessor;
```

}

<h3 class="fw-bold mb-3" style="color:#003366;">
📝 Assessment – @Model.Candidate.FullName
</h3>

<div class="progress mb-3" style="height:18px;">
<div id="progressBar" class="progress-bar bg-success" style="width:0%"></div>
</div>

<style>

.glass-box{
background:rgba(255,255,255,0.8);
backdrop-filter:blur(10px);
padding:20px;
border-radius:16px;
box-shadow:0 10px 35px rgba(0,0,0,0.15);
}

.question-box{
border:1px solid #c6d4ec;
background:#f3f7ff;
border-radius:10px;
padding:14px;
margin-bottom:12px;
}

.nav-tabs{
position:sticky;
top:0;
z-index:10;
background:white;
}

.btn-save{
background:#ffd84d;
color:#003366;
font-weight:600;
}

.btn-submit{
background:#003366;
color:white;
font-weight:600;
}

</style>

<form asp-action="Perform"
asp-route-id="@Model.Id"
method="post"
enctype="multipart/form-data">

<ul class="nav nav-tabs mb-3">

@for(int i=0;i<sections.Count;i++)
{

<li class="nav-item">
<button type="button"
class="nav-link @(i==0?"active":"")"
data-bs-toggle="tab"
data-bs-target="#tab-@i">

@sections[i].Category

</button>
</li>
}

<li class="nav-item">
<button type="button"
class="nav-link"
data-bs-toggle="tab"
data-bs-target="#tab-summary">
Summary
</button>
</li>

</ul>

<div class="tab-content glass-box">

@for(int i=0;i<sections.Count;i++)
{
var sec=sections[i];

string sectionCommentKey=$"SECTION_COMMENT_{sec.Id}";
saved.TryGetValue(sectionCommentKey,out var savedSectionComment);

<div class="tab-pane fade @(i==0?"show active":"")" id="tab-@i">

@foreach(var q in sec.Questions)
{
string qId=q.Id.ToString();

string ansKey=$"ANS_{qId}";
string scrKey=$"SCORE_{qId}";
string uploadKey=$"FILE_UPLOAD_{qId}";

saved.TryGetValue(ansKey,out var savedAns);
saved.TryGetValue(scrKey,out var savedScore);

<div class="question-box">

<div class="row align-items-center">

<div class="col-md-8">
<label class="fw-bold">@q.Text</label>
</div>

<div class="col-md-4">

<select class="form-select response-dropdown"
name="@ansKey"
data-id="@qId"
@(editable?"":"disabled")>

<option value="">-- select --</option>

<option value="0" selected="@(savedAns=="0")">Dependent</option>
<option value="1" selected="@(savedAns=="1")">Physical Prompt</option>
<option value="2" selected="@(savedAns=="2")">Verbal Prompt</option>
<option value="3" selected="@(savedAns=="3")">Independent</option>

</select>

</div>

</div>

<input type="hidden"
id="score_@qId"
name="@scrKey"
value="@(savedScore??"0")"
class="score-input"/>

<label class="fw-semibold mt-2">📎 Upload Evidence</label>

<input type="file"
name="@uploadKey"
class="form-control"
multiple
@(editable?"":"disabled")/>

</div>
}

<div class="mt-3">

<label class="fw-bold">Section Comments</label>

<textarea name="@sectionCommentKey"
rows="3"
class="form-control"
placeholder="Enter overall comments for this section"
@(editable?"":"readonly")>

@savedSectionComment

</textarea>

</div>

<div class="alert alert-light mt-2 fw-bold">
Section Score: <span class="sectionScore">0</span>
</div>

</div>
}

<div class="tab-pane fade" id="tab-summary">

<label class="fw-bold">Overall Summary Comments</label>

<textarea name="SUMMARY_COMMENTS"
rows="4"
class="form-control mb-3"
@(editable?"":"readonly")>

@(saved.GetValueOrDefault("SUMMARY_COMMENTS"))

</textarea>

<div class="alert alert-info fw-bold">

Total Score: <span id="totalScore"></span> /

<span id="maxScore"></span> |

<span id="percentScore"></span>

</div>

</div>

</div>

<div class="text-end mt-3">

@if(editable)
{ <button class="btn btn-save me-2" name="actionType" value="save">
💾 Save </button>

<button class="btn btn-submit" name="actionType" value="submit">
📤 Submit
</button>
}
else
{
<button class="btn btn-secondary" disabled>
Assessment Locked
</button>
}

</div>

</form>

<script>

let dropdowns;
let currentIndex=0;

document.addEventListener("DOMContentLoaded",()=>{

dropdowns=document.querySelectorAll(".response-dropdown");

dropdowns.forEach((d,i)=>{d.dataset.index=i});

computeTotals();

setInterval(autoSave,30000);

});

document.addEventListener("change",e=>{

if(e.target.classList.contains("response-dropdown")){

let id=e.target.dataset.id;

document.getElementById("score_"+id).value=e.target.value;

currentIndex=Number(e.target.dataset.index);

moveNext();

computeTotals();

}

});

document.addEventListener("keydown",e=>{

if(["0","1","2","3"].includes(e.key)){

let d=dropdowns[currentIndex];

if(!d) return;

d.value=e.key;

let id=d.dataset.id;

document.getElementById("score_"+id).value=e.key;

moveNext();

computeTotals();

}

});

function moveNext(){

currentIndex++;

if(currentIndex<dropdowns.length){

dropdowns[currentIndex].focus();

}

}

function computeTotals(){

let total=0;

let max=document.querySelectorAll(".score-input").length*3;

let answered=0;

document.querySelectorAll(".score-input").forEach(i=>{

let v=Number(i.value);

if(!isNaN(v)){
total+=v;
answered++;
}

});

document.getElementById("totalScore").innerText=total;

document.getElementById("maxScore").innerText=max;

document.getElementById("percentScore").innerText=((total/max)*100).toFixed(1)+"%";

updateProgress(answered);

}

function updateProgress(answered){

let totalQuestions=document.querySelectorAll(".score-input").length;

let percent=(answered/totalQuestions)*100;

document.getElementById("progressBar").style.width=percent+"%";

}

function autoSave(){

let form=document.querySelector("form");

let data=new FormData(form);

fetch(form.action,{
method:"POST",
body:data
});

}

</script>
